# ===========================================================================
# LEDLight — переменные окружения
# ===========================================================================
# Скопируйте в .env.local (разработка) или задайте в Vercel Project Settings →
# Environment Variables (production). Реальные значения НЕ коммитьте.
# Без переменных проект работает в демо-режиме (формы принимаются, но никуда
# не отправляются). См. README.md → «Production deployment checklist».
# ===========================================================================


# ─── Публичные (NEXT_PUBLIC_*) ───────────────────────────────────────────
# Доступны и на клиенте, и на сервере. Инлайнятся в сборку.

# Canonical URL сайта. В проде — боевой домен (https://...). Обязательно для
# production: используется в metadataBase, sitemap, OG-тегах, JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Контакты компании (шапка/футер/JSON-LD/OG-картинка). Если не заданы —
# берутся дефолтные значения из src/lib/site-config.ts.
NEXT_PUBLIC_COMPANY_PHONE=+7 (495) 123-45-67
NEXT_PUBLIC_COMPANY_EMAIL=info@ledlight.ru
NEXT_PUBLIC_COMPANY_TELEGRAM=https://t.me/ledlight
NEXT_PUBLIC_COMPANY_ADDRESS=Московская обл., г. Люберцы
NEXT_PUBLIC_COMPANY_HOURS=Пн–Пт: 9:00–18:00
NEXT_PUBLIC_COMPANY_LEGAL_NAME=ООО «ЛЕДЛАЙТ»


# ─── Email (Resend) — обязательно для production ─────────────────────────
# Без этих трёх переменных заявки не отправляются на почту (демо-режим).
# Resend: https://resend.com → верифицировать домен отправителя + SPF/DKIM.
# MAIL_FROM должен быть с верифицированного домена (НЕ onboarding@resend.dev).
RESEND_API_KEY=
MAIL_FROM=LEDLight <noreply@your-verified-domain.ru>
MAIL_TO=info@your-domain.ru


# ─── Хранилище файлов (Vercel Blob) — опционально, production ────────────
# Для загрузки ТЗ/фото из форм. Без токена файлы не сохраняются (демо-режим),
# но заявка всё равно принимается. Включается в Vercel Dashboard → Storage →
# Blob → Create Blob Store → скопировать BLOB_READ_WRITE_TOKEN.
BLOB_READ_WRITE_TOKEN=


# ─── Rate limit (Upstash Redis) — опционально, для прод-rate-limit ───────
# In-memory лимитер (src/lib/rate-limit.ts) не подходит для serverless: каждый
# инстанс функции считает лимит отдельно. Для строгого лимита создайте БД в
# Upstash Redis и задайте ОБЕ переменные.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ─── CRM (Bitrix24) — опционально, production ───────────────────────────
# Входящий webhook из Bitrix24 (Разработчикам → Другое → Входящий вебхук,
# права на crm.lead.add). Без него лиды не создаются в CRM (демо-режим).
BITRIX24_WEBHOOK_URL=
