# ─── Приложение ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_COMPANY_PHONE=+7 (495) 123-45-67
NEXT_PUBLIC_COMPANY_EMAIL=info@ledlight.ru
NEXT_PUBLIC_COMPANY_TELEGRAM=https://t.me/ledlight

# ─── Email (Resend) — необязательно ──────────────────────────
# Без этих переменных заявки не отправляются на почту (демо-режим).
# Задайте все три, чтобы включить email-уведомления.
RESEND_API_KEY=
MAIL_FROM=LEDLight <noreply@your-verified-domain.ru>
MAIL_TO=info@your-domain.ru

# ─── CRM (Bitrix24) — необязательно ──────────────────────────
# Входящий webhook из Bitrix24 (Разработчикам → Другое → Входящий вебхук).
# Без него лиды не создаются в CRM (демо-режим).
BITRIX24_WEBHOOK_URL=

# ─── Хранилище файлов (Vercel Blob) — необязательно ──────────
# Без токена загруженные файлы (ТЗ, фото) не сохраняются (демо-режим),
# но заявка всё равно принимается.
BLOB_READ_WRITE_TOKEN=
